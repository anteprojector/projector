# LiveKit credentials
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
LIVEKIT_URL=wss://your-project.livekit.cloud

# OpenAI API key (for realtime model or STT/TTS)
OPENAI_API_KEY=your_openai_api_key

# Optional OpenAI model for non-realtime/discrete projector inference
OPENAI_DISCRETE_MODEL=gpt-4o-mini

# Convex deployment URL (for persisting transcripts)
CONVEX_URL=https://your-deployment.convex.cloud

# Secret for authenticating with Convex HTTP endpoint
VOICE_AGENT_SECRET=your_secret_here

# Set to "true" to use OpenAI Realtime API, "false" for STT->LLM->TTS pipeline
ENABLE_REALTIME_MODEL=true

# Optional realtime overrides
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=alloy
